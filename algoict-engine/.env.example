# AlgoICT Engine — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# TopstepX (MNQ Intraday)
TOPSTEPX_USERNAME=
TOPSTEPX_API_KEY=
TOPSTEPX_API_URL=https://api.topstepx.com/api
TOPSTEPX_WS_URL=wss://realtime.topstepx.com/api

# Alpaca (S&P 500 Swing)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# Telegram Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI
ANTHROPIC_API_KEY=

# Market Data / News / Calendar
# Finnhub   — economic calendar (https://finnhub.io/register — free tier)
# Alpha V.  — news sentiment    (https://www.alphavantage.co — free tier 25 req/day)
# MenthorQ  — options / GEX data
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
MENTHORQ_API_KEY=
